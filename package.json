{
  "name": "netsapiens-mcp",
  "version": "1.1.1",
  "description": "NetSapiens MCP Server for NetSapiens Platform Integration",
  "main": "build/index.js",
  "bin": {
    "netsapiens-mcp": "build/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "watch": "tsx watch src/index.ts",
    "clean": "rimraf build",
    "prebuild": "npm run clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "netsapiens",
    "voip",
    "oitvoip",
    "api",
    "integration"
  ],
  "author": "OITVOIP",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "axios": "^1.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "build/**/*",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phoneware/netsapiens-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/phoneware/netsapiens-mcp/issues"
  },
  "homepage": "https://github.com/phoneware/netsapiens-mcp#readme"
}
