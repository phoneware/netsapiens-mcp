# =============================================================================
# NetSapiens MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Required: NetSapiens API ---
# Base URL of your NetSapiens API instance
NETSAPIENS_API_URL=https://edge.phoneware.cloud

# --- Required for HTTP transport: operator-level NS OAuth credentials ---
# These are used server-side to authenticate users via the browser login page.
# User credentials never pass through the MCP transport or LLM.
NETSAPIENS_OAUTH_CLIENT_ID=
NETSAPIENS_OAUTH_CLIENT_SECRET=

# --- Required for production: public base URL ---
# The externally reachable URL of this MCP server.
# Used for OAuth metadata discovery and redirect URIs.
# Must match what MCP clients use to connect.
MCP_BASE_URL=https://mcp.yourdomain.com

# --- Optional: transport and networking ---
# MCP_TRANSPORT=http          # http (default in Docker) or stdio
# MCP_PORT=3000               # Port to listen on (default: 3000)
# MCP_HOST=0.0.0.0            # Bind address (default: 0.0.0.0)

# --- Optional: CORS ---
# MCP_CORS_ORIGIN=*           # Allowed origins (default: * — restrict in production)

# --- Optional: logging ---
# LOG_LEVEL=info              # debug, info, warn, error (default: info)
# DEBUG=false                 # Enable debug logging (default: false)
